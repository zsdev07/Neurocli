<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.soccerlegacy.game">

    <!-- Required for NativeActivity -->
    <uses-feature android:glEsVersion="0x00030000"
        android:required="true" />

    <!-- Screen orientation locked to portrait (like Soccer Superstar) -->
    <application
        android:label="@string/app_name"
        android:hasCode="false">   <!-- Pure native, no Java code needed at runtime -->

        <activity
            android:name="android.app.NativeActivity"
            android:label="@string/app_name"
            android:screenOrientation="portrait"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="true">

            <!-- Tells NativeActivity which .so library to load -->
            <meta-data
                android:name="android.app.lib_name"
                android:value="soccerlegacy" />

            <!-- App launches from home screen -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>
    </application>

</manifest>
